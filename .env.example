# Optional: Server-side fallback API key.
# Leave empty for BYOK-only mode where each user provides their own key via the UI.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model (users can override in the UI)
# Examples: google/gemini-2.0-flash-001, anthropic/claude-sonnet-4-5, openai/gpt-4o
LLM_MODEL=google/gemini-2.0-flash-001

REDIS_URL=redis://localhost:6379
OUTPUT_DIR=./outputs
LOG_LEVEL=INFO
ARXIV_MAX_RESULTS=5
BACKEND_URL=http://localhost:8000
